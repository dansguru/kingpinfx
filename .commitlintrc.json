{
    "extends": ["@commitlint/config-conventional"],
    "rules": {
        "body-leading-blank": [0],
        "footer-leading-blank": [0],
        "header-max-length": [0],
        "scope-case": [0],
        "subject-case": [0, "always"],
        "subject-empty": [0],
        "subject-full-stop": [0],
        "type-case": [0],
        "type-empty": [0],
        "type-enum": [
            0
        ]
    }
}
